PROJECT_ID="PROJECT_ID"
MODEL="gemini-2.5-flash"
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID
GOOGLE_CLOUD_LOCATION=asia-southeast1
MAPS_API_KEY=
# Substring applied to every resource this app creates (Keep search, Calendar/Tasks filters).
# SIDEKICK_RESOURCE_LABEL=sidekick.amngupta.com

# --- Sidekick: Flask (public) + ADK FastAPI (loopback only) ---
PORT=8080
HOST=0.0.0.0
ADK_INTERNAL_PORT=8001
# Optional: long agent runs (seconds)
# ADK_PROXY_TIMEOUT=300
# CORS_ALLOW_ORIGINS=*
# ADK_TRACE_TO_CLOUD=0
# ADK_OTEL_TO_CLOUD=0
# UVICORN_LOG_LEVEL=warning

# --- Google OAuth (gate /api; omit CLIENT_ID to disable and keep open API) ---
# FLASK_SECRET_KEY=long-random-string-required-when-oauth-enabled
# GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=xxx
# Must match Google Cloud Console "Authorized redirect URIs" exactly.
# IMPORTANT: use the same host/scheme you use in the browser (e.g. localhost vs Cloud Run URL).
# OAUTH_REDIRECT_URI=http://localhost:8080/auth/google/callback
# Optional: restrict sign-in to one domain (email must end with @domain)
# AUTH_ALLOWED_EMAIL_DOMAIN=yourcompany.com
# Behind HTTPS proxy / Cloud Run: TRUST_PROXY_HEADERS=1 (auto if K_SERVICE is set)
# SESSION_COOKIE_SECURE defaults ON on Cloud Run; override with SESSION_COOKIE_SECURE=0 if needed
# SESSION_COOKIE_SAMESITE=Lax
#
# Google Calendar + Tasks + Keep (product APIs): enable each API in APIs & Services > Library.
# The app requests OAuth scopes only for integrations left enabled below (default: all on).
# Changing these flags changes requested scopes — users should sign in again to refresh tokens.
# SIDEKICK_ENABLE_GOOGLE_CALENDAR=0   # DB-only schedule tools; omit calendar.events scope
# SIDEKICK_ENABLE_GOOGLE_TASKS=0      # DB-only task tools; omit tasks scope
# SIDEKICK_ENABLE_GOOGLE_KEEP=0       # DB-only notes; omit keep scope (Keep is often Workspace-only)
#   https://developers.google.com/workspace/keep/api
# Tokens are stored in sidekick_google_oauth (refresh_token for offline access).
# After first successful login, set GOOGLE_OAUTH_PROMPT=select_account to avoid
# forcing consent on every sign-in (optional).
# GOOGLE_OAUTH_PROMPT=consent

# --- AlloyDB / PostgreSQL (required for task/schedule/note tools) ---
# Option A: direct URL (Auth Proxy or IP + TLS as required by your network)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Option B: Google AlloyDB connector (typical on Cloud Run with IAM DB auth)
# ALLOYDB_INSTANCE_URI=projects/PROJECT/locations/REGION/clusters/CLUSTER/instances/INSTANCE
# ALLOYDB_USER=your-db-user
# ALLOYDB_DB=postgres
# ALLOYDB_ENABLE_IAM_AUTH=1
# ALLOYDB_PASSWORD=

# Optional pool tuning
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
#
# Rows in sidekick_tasks / sidekick_notes / sidekick_calendar_events are scoped by
# owner_sub (= ADK user_id, i.e. Google OAuth sub when Flask OAuth is enabled).

# --- Optional MCP (stdio): command + JSON array of args ---
# SIDEKICK_MCP_TASK_COMMAND=npx
# SIDEKICK_MCP_TASK_ARGS=["-y","@some/package"]
# SIDEKICK_MCP_CALENDAR_COMMAND=npx
# SIDEKICK_MCP_CALENDAR_ARGS=[]
# SIDEKICK_MCP_NOTES_COMMAND=npx
# SIDEKICK_MCP_NOTES_ARGS=[]
